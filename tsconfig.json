{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationDir": "dist/types",
    "outDir": "dist",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false,
    "paths": {
      "core-app/*": ["../openproject/frontend/src/app/*"]
    }
  },
  "include": [
    "frontend/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "frontend/**/*.spec.ts"
  ]
}
