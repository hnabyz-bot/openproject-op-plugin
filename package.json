{
  "name": "openproject-op-plugin",
  "version": "0.1.0",
  "description": "OpenProject op-plugin frontend module",
  "private": true,
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint 'frontend/**/*.ts'"
  },
  "devDependencies": {
    "@angular/common": "^17.0.0",
    "@angular/core": "^17.0.0",
    "@types/jest": "^29.5.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0",
    "zone.js": "^0.14.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom",
    "testMatch": [
      "<rootDir>/frontend/**/*.spec.ts"
    ],
    "moduleNameMapper": {
      "^core-app/(.*)$": "<rootDir>/../openproject/frontend/src/app/$1"
    },
    "collectCoverageFrom": [
      "frontend/**/*.ts",
      "!frontend/**/*.spec.ts",
      "!frontend/module/main.ts"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 80
      }
    }
  }
}
